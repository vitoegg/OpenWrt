### Init
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y
CONFIG_GRUB_TIMEOUT="1"

### Basic
CONFIG_KERNEL_MPTCP=y
CONFIG_KERNEL_MPTCP_IPV6=y
CONFIG_PACKAGE_autocore-x86=y
CONFIG_PACKAGE_bind-host=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_default-settings=y
CONFIG_TARGET_KERNEL_PARTSIZE=256
CONFIG_TARGET_ROOTFS_PARTSIZE=2048
# CONFIG_KERNEL_KALLSYMS is not set

### Removed: builds everything, unnecessary for dedicated router
# CONFIG_ALL_KMODS is not set
# CONFIG_ALL_NONSHARED is not set

### Image format (squashfs + EFI only)
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_GRUB_EFI_IMAGES=y
# CONFIG_TARGET_ROOTFS_EXT4 is not set
# CONFIG_GRUB_IMAGES is not set
# CONFIG_ISO_IMAGES is not set
# CONFIG_VDI_IMAGES is not set
# CONFIG_VMDK_IMAGES is not set
# CONFIG_VHDX_IMAGES is not set
# CONFIG_TARGET_ROOTFS_TARGZ is not set

### Kernel driver (UN100D: Intel i226 + NVMe)
CONFIG_PACKAGE_kmod-igc=y
CONFIG_PACKAGE_kmod-nvme=y

